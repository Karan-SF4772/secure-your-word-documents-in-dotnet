<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]ProtectDoc</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProtectDoc.styles.css" asp-append-version="true" />

    <!-- Syncfusion ASP.NET Core controls styles -->
    <link rel="stylesheet" href="https://cdn.syncfusion.com/ej2/31.2.2/fluent.css" />
    <!-- Syncfusion ASP.NET Core controls scripts -->
    <script src="https://cdn.syncfusion.com/ej2/31.2.2/dist/ej2.min.js"></script>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">ProtectDoc</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown me-2">
                            <button class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                                Encryption
                            </button>
                            <div class="dropdown-menu p-3" style="width: 250px;">
                                @using (Html.BeginForm("EncryptDocument", "Home", FormMethod.Get))
                                {
                                    <ejs-button id="btnEncrypt" content="Encrypt Document"></ejs-button>
                                }
                                <ejs-button id="btnDecrypt" content="Decrypt Document"></ejs-button>
                            </div>
                        </li>
                        <li class="nav-item dropdown me-2">
                            <button class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                                Protection Types
                            </button>
                            <div class="dropdown-menu p-3" style="width: 250px;">
                                <ejs-button id="btnAllowComments" content="Allow Editing Comments Only"></ejs-button>
                                <ejs-button id="btnAllowFormFields"
                                    content="Allow Editing Form Fields Only"></ejs-button>
                                <ejs-button id="btnAllowRevisions" content="Allow Revision Only"></ejs-button>
                                <ejs-button id="btnAllowReading" content="Allow Reading Only"></ejs-button>
                                <ejs-button id="btnRemoveProtection" content="Remove Protection"></ejs-button>
                            </div>
                        </li>
                        <li class="nav-item dropdown me-2">
                            <button class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                                Editable Ranges
                            </button>
                            <div class="dropdown-menu p-3" style="width: 250px;">
                                <ejs-button id="btnAddEditableRange" content="Add Editable Range"></ejs-button>
                                <ejs-button id="btnRemoveEditableRange" content="Remove Editable Range"></ejs-button>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ProtectDoc - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Syncfusion ASP.NET Core Script Manager -->
    <ejs-scripts></ejs-scripts>
</body>

</html>